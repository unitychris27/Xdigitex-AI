# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://xdigitex:changeme@localhost:5432/xdigitex
POSTGRES_PASSWORD=changeme

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-random-secret-here

# ── AI Models ─────────────────────────────────────────────────────────────────
# DeepSeek (builder agent) — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# NVIDIA NIM (Kimi K2.6 planner) — https://build.nvidia.com
NVIDIA_API_KEY=

# Google Gemini (screenshot QA + vision) — https://aistudio.google.com
GEMINI_API_KEY=

# xAI / Grok (fallback) — https://console.x.ai
XAI_API_KEY=

# OpenRouter (model routing) — https://openrouter.ai
OPENROUTER_API_KEY=

# OpenAI (optional fallback) — https://platform.openai.com
OPENAI_API_KEY=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:8080/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Brevo) ─────────────────────────────────────────────────────────────
# https://www.brevo.com → SMTP & API
BREVO_API_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_PASSWORD=
