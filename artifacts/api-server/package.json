{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "pnpm run browser:setup && node --enable-source-maps ./dist/index.mjs",
    "browser:setup": "playwright install chromium 2>&1; echo '[browser:setup] done'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "adm-zip": "^0.5.17",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "openai": "^6.42.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "playwright": "^1.60.0",
    "ssh2": "^1.17.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/ssh2": "^1.15.5",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
